{
  "name": "textforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first text workbench for editing, visualising, and transforming structured text.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build --config vite.file.config.ts && node scripts/write-file-index.mjs",
    "build:module": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:unit": "vitest run src/**/*.test.ts",
    "test:smoke": "vitest run src/app/App.smoke.test.tsx --environment jsdom",
    "test:security": "vitest run src/security.verify.test.js",
    "verify:file": "node scripts/verify-file-build.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "check": "npm run test && npm run build && npm run verify:file && npm run verify:security"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.4.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.3",
    "@lezer/highlight": "^1.2.1",
    "@preact/preset-vite": "^2.9.3",
    "@vitejs/plugin-legacy": "^6.0.0",
    "@viz-js/viz": "^3.17.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "bpmn-js": "^18.16.1",
    "codemirror": "^6.0.1",
    "cytoscape": "^3.31.2",
    "dompurify": "^3.4.4",
    "fengari": "^0.1.5",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-metrics": "^2.4.0",
    "highlight.js": "^11.11.1",
    "jsmind": "^0.8.7",
    "katex": "^0.16.47",
    "lucide-preact": "^0.468.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.4.1",
    "preact": "^10.25.1",
    "sigma": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
