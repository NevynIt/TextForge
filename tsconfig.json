{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@textforge/itm": ["external/ITM/dist/index.d.ts"],
      "@textforge/itm/node": ["external/ITM/dist/node.d.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "vite.file.config.ts", "vitest.config.ts", "scripts"],
  "references": []
}
