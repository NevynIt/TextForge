{
  "name": "@textforge/itm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.js"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "node --check src/index.js && node --check src/node.js",
    "test": "node --test test/index.test.js",
    "lint": "node scripts/check.mjs",
    "typecheck": "node --check src/index.js && node --check src/node.js"
  },
  "dependencies": {
    "@textforge/core": "workspace:*",
    "@textforge/workspace": "workspace:*",
    "fast-xml-parser": "^5.8.0",
    "yaml": "^2.8.0"
  }
}
